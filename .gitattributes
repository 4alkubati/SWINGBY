# Normalize line endings: store LF in the repo, let editors do what they want.
# Kills the "LF will be replaced by CRLF" warning spam on Windows.
* text=auto

# Always LF — these break with CRLF
*.sh text eol=lf

# Binary — never diff or normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.keystore binary
