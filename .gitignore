# Obsidian — personal vault config, never commit
.obsidian/

# Local-only credentials vault (test accounts + API keys + service notes).
# Only the README is committed so the folder structure is discoverable.
credentials/*
!credentials/README.md

# Legacy test-credential patterns (kept so any stragglers stay ignored)
SEED ACCOUNT FOR TESTING*
SEED ACCOUNT*
seed-account*
test-credentials*

# Live credentials for autonomous agents — NEVER commit
# Templates (*.template.txt) are committed; filled-in files are not.
.claude/secrets/*
!.claude/secrets/*.template.txt
!.claude/secrets/.gitkeep
!.claude/secrets/README.md

# Personal operator profile — keep local, never push
AGENTS/claude/KIRA.md
