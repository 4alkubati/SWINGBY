# SwingBy Mobile — Environment Variables
#
# Copy this file to .env and fill in values.
# Expo loads .env automatically via expo-constants.

# Backend API URL — points to the deployed Render backend by default.
# For local development, swap to one of:
#   http://localhost:8000       (web browser + iOS simulator)
#   http://10.0.2.2:8000        (Android emulator)
#   http://<your-LAN-IP>:8000   (physical phone on same Wi-Fi)
EXPO_PUBLIC_API_URL=https://swingbyy-api.onrender.com

# Sentry DSN — optional. Leave commented out to disable error reporting.
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0

# Google Maps API key — activates all map screens (NearbyMapScreen, and any
# future MapView usage). app.config.js injects it into the Android/iOS native
# config; it never appears in a committed file or the JS bundle.
#
# ── THIS IS THE ONE PLACE TO PASTE THE REAL KEY (in .env, not this file) ──
# For EAS/production builds set the same variable in EAS instead:
#   eas env:create --name GOOGLE_MAPS_API_KEY --value <key>
#
# Note: the key only takes effect in a dev build / prebuild / EAS build
# (`npx expo run:android` or `eas build`). Expo Go ships its own Maps key
# and ignores this value on Android; iOS Expo Go falls back to Apple Maps.
GOOGLE_MAPS_API_KEY=
