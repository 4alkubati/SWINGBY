{
  "expo": {
    "name": "SwingBy",
    "slug": "swingby",
    "version": "1.0.0",
    "scheme": "swingby",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07080a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.swingby.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SwingBy uses your location to show nearby service providers.",
        "NSLocationAlwaysUsageDescription": "SwingBy uses your location to show nearby service providers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07080a"
      },
      "googleMapsApiKey": "AIzaSyDW2h2noMJ_PyVCwub17DIwi8xb8BAnyJw",
      "package": "com.swingby.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SwingBy uses your location to show nearby service providers."
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
